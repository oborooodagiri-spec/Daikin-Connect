  category       String   @db.VarChar(100)
  work_type      String   @db.VarChar(100)
  item_name      String   @db.VarChar(255)
  capacity_unit  String   @db.VarChar(50)
  capacity_range String   @db.VarChar(100)
  price          Decimal  @db.Decimal(15, 2)
